{
  "name": "edecompte-backend",
  "version": "1.0.0",
  "description": "Backend API for e-Décompte AGEROUTE",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "ts-node scripts/migrate.ts",
    "db:migrate:create": "ts-node scripts/create-migration.ts",
    "db:seed": "ts-node scripts/seed.ts",
    "db:drop": "ts-node scripts/drop-db.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "typescript": "^5.2.2",
    "sequelize": "^6.33.0",
    "pg": "^8.11.1",
    "pg-hstore": "^2.3.4",
    "redis": "^4.6.10",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^7.0.0",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "axios": "^1.5.0",
    "amqplib": "^0.10.3",
    "nodemailer": "^6.9.6",
    "uuid": "^9.0.0",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.1",
    "@types/jest": "^29.5.7",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.7.3",
    "@typescript-eslint/parser": "^6.7.3",
    "prettier": "^3.0.3"
  }
}
